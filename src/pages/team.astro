---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const mainTeam = [
  {
    name: '尾川 慎二',
    nameEn: 'Shinji Ogawa',
    model: '',
    description: '',
    photo: '/team/ogawa.jpg',
  },
  {
    name: '堀内 礼',
    nameEn: 'Rei Horiuchi',
    model: 'ZERO',
    description: 'ZERO モデルの監修ライダー。グラトリからフリーランまで幅広いスタイルで表現するオールラウンダー。',
    photo: '/team/horiuchi.jpg',
  },
  {
    name: '田中 彪麻',
    nameEn: 'Hyoma Tanaka',
    model: '',
    description: '',
    photo: '/team/tanaka.jpg',
  },
  {
    name: '土谷 英虎',
    nameEn: 'Hidetora Tsuchiya',
    model: '',
    description: '',
    photo: '/team/tsuchiya.jpg',
  },
  {
    name: '西岡 佑真',
    nameEn: 'Yuma Nishioka',
    model: '',
    description: '',
    photo: '/team/nishioka.jpg',
  },
];

const rdTeam = [
  {
    name: '勝呂 裕一郎',
    nameEn: 'Yuichiro Suguro',
    model: 'RD',
    description: '',
    photo: '/team/suguro.jpg',
  },
  {
    name: '蘇原 空斗',
    nameEn: 'Kuto Sohara',
    model: 'RD',
    description: '',
    photo: '/team/sohara.jpg',
  },
  {
    name: '関谷 陸',
    nameEn: 'Riku Sekiya',
    model: 'RD',
    description: '',
    photo: '/team/sekiya.jpg',
  },
];
---

<Layout
  title="TEAM — SPREAD SNOWBOARDS"
  description="SPREAD SNOWBOARDSのチームライダー紹介。"
>
  <!-- Page Header -->
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-8 border-b border-white/5">
    <p class="text-red-500 text-[10px] tracking-[0.4em] uppercase mb-3">RIDERS</p>
    <h1 class="text-4xl sm:text-5xl font-black tracking-tight italic">TEAM</h1>
  </div>

  <!-- Main Team -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="flex items-center gap-4 mb-10">
      <h2 class="text-xs tracking-[0.4em] uppercase text-white/40 font-medium">TEAM RIDERS</h2>
      <div class="flex-1 h-px bg-white/5"></div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {mainTeam.map(rider => (
        <div class="group">
          <div class="aspect-square overflow-hidden mb-4 bg-white/5">
            {rider.photo ? (
              <img
                src={`${base}${rider.photo}`}
                alt={rider.name}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-white/20 text-2xl font-black italic">{rider.name.charAt(0)}</span>
              </div>
            )}
          </div>
          {rider.model && (
            <p class="text-[10px] tracking-[0.3em] uppercase text-white/30 mb-1">{rider.model}</p>
          )}
          <h2 class="text-sm font-black italic text-white mb-0.5">{rider.name}</h2>
          <p class="text-white/30 text-[10px] tracking-widest">{rider.nameEn}</p>
          {rider.description && (
            <p class="text-white/40 text-xs leading-relaxed mt-3">{rider.description}</p>
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- RD Series Team -->
  <div class="max-w-7xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-4 mb-10">
      <h2 class="text-xs tracking-[0.4em] uppercase text-white/40 font-medium">RD SERIES</h2>
      <div class="flex-1 h-px bg-white/5"></div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {rdTeam.map(rider => (
        <div class="group">
          <div class="aspect-square overflow-hidden mb-4 bg-white/5">
            {rider.photo ? (
              <img
                src={`${base}${rider.photo}`}
                alt={rider.name}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-white/20 text-2xl font-black italic">{rider.name.charAt(0)}</span>
              </div>
            )}
          </div>
          {rider.model && (
            <p class="text-[10px] tracking-[0.3em] uppercase text-white/30 mb-1">{rider.model}</p>
          )}
          <h2 class="text-sm font-black italic text-white mb-0.5">{rider.name}</h2>
          <p class="text-white/30 text-[10px] tracking-widest">{rider.nameEn}</p>
          {rider.description && (
            <p class="text-white/40 text-xs leading-relaxed mt-3">{rider.description}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>
