---
import Layout from '../layouts/Layout.astro';

const riders = [
  {
    name: '堀内 礼',
    nameEn: 'Rei Horiuchi',
    model: 'ZERO',
    description: 'ZERO モデルの監修ライダー。グラトリからフリーランまで幅広いスタイルで表現するオールラウンダー。',
    social: '',
  },
];
---

<Layout
  title="TEAM — SPREAD SNOWBOARDS"
  description="SPREAD SNOWBOARDSのチームライダー紹介。"
>
  <!-- Page Header -->
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-8 border-b border-white/5">
    <p class="text-red-500 text-[10px] tracking-[0.4em] uppercase mb-3">RIDERS</p>
    <h1 class="text-4xl sm:text-5xl font-black tracking-tight italic">TEAM</h1>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {riders.map(rider => (
        <div class="border border-white/5 p-8 hover:border-white/15 transition-colors">
          <!-- Avatar placeholder -->
          <div class="w-16 h-16 bg-white/5 border border-white/10 flex items-center justify-center mb-6">
            <span class="text-white/20 text-xl font-black italic">
              {rider.name.charAt(0)}
            </span>
          </div>

          <p class="text-[10px] tracking-[0.3em] uppercase text-white/30 mb-1">{rider.model}</p>
          <h2 class="text-xl font-black italic text-white mb-1">{rider.name}</h2>
          <p class="text-white/30 text-xs tracking-widest mb-5">{rider.nameEn}</p>

          <p class="text-white/50 text-sm leading-relaxed">{rider.description}</p>
        </div>
      ))}
    </div>
  </div>
</Layout>
