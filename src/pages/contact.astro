---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="CONTACT — SPREAD SNOWBOARDS"
  description="SPREAD SNOWBOARDSへのお問い合わせ。製品についてのご質問、ご注文等はこちらから。"
>
  <!-- Page Header -->
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-8 border-b border-black/5">
    <p class="text-red-600 text-[10px] tracking-[0.4em] uppercase mb-3">GET IN TOUCH</p>
    <h1 class="text-4xl sm:text-5xl font-black tracking-tight italic">CONTACT</h1>
  </div>

  <div class="max-w-3xl mx-auto px-6 py-16">
    <p class="text-black/40 text-sm leading-relaxed mb-12">
      製品についてのご質問、お取り扱いのご相談、その他お問い合わせは<br class="hidden sm:block" />
      以下のフォームよりお気軽にご連絡ください。
    </p>

    <form
      name="contact"
      method="POST"
      action="mailto:ken.furuta@37design.co.jp"
      enctype="text/plain"
      class="space-y-6"
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-[10px] tracking-[0.3em] uppercase text-black/30 mb-2">
            お名前 <span class="text-red-600">*</span>
          </label>
          <input
            type="text"
            name="name"
            required
            class="w-full bg-transparent border border-black/15 text-black text-sm px-4 py-3 focus:outline-none focus:border-black/40 transition-colors placeholder-black/20"
            placeholder="山田 太郎"
          />
        </div>

        <div>
          <label class="block text-[10px] tracking-[0.3em] uppercase text-black/30 mb-2">
            メールアドレス <span class="text-red-600">*</span>
          </label>
          <input
            type="email"
            name="email"
            required
            class="w-full bg-transparent border border-black/15 text-black text-sm px-4 py-3 focus:outline-none focus:border-black/40 transition-colors placeholder-black/20"
            placeholder="your@email.com"
          />
        </div>
      </div>

      <div>
        <label class="block text-[10px] tracking-[0.3em] uppercase text-black/30 mb-2">
          件名
        </label>
        <select
          name="subject"
          class="w-full bg-white border border-black/15 text-black/70 text-sm px-4 py-3 focus:outline-none focus:border-black/40 transition-colors"
        >
          <option value="">選択してください</option>
          <option value="product">製品について</option>
          <option value="shop">取り扱い店舗について</option>
          <option value="dealer">販売代理店について</option>
          <option value="other">その他</option>
        </select>
      </div>

      <div>
        <label class="block text-[10px] tracking-[0.3em] uppercase text-black/30 mb-2">
          メッセージ <span class="text-red-600">*</span>
        </label>
        <textarea
          name="message"
          required
          rows="6"
          class="w-full bg-transparent border border-black/15 text-black text-sm px-4 py-3 focus:outline-none focus:border-black/40 transition-colors placeholder-black/20 resize-none"
          placeholder="お問い合わせ内容をご記入ください"
        ></textarea>
      </div>

      <button
        type="submit"
        class="inline-flex items-center gap-3 bg-black text-white text-xs font-bold tracking-[0.2em] uppercase px-8 py-3 hover:bg-red-600 transition-colors duration-200"
      >
        <span>SEND MESSAGE</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>

    <div class="mt-16 pt-12 border-t border-black/5 text-center">
      <p class="text-black/20 text-[10px] tracking-[0.3em] uppercase mb-6">FOLLOW US</p>
      <a
        href="https://www.instagram.com/spreadsnowboards/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 border border-black/15 text-black/60 text-xs font-bold tracking-[0.15em] uppercase px-6 py-3 hover:border-black/40 hover:text-black transition-colors duration-200"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
        </svg>
        <span>Instagram</span>
      </a>
    </div>
  </div>
</Layout>
