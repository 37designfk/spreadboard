---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="CONTACT — SPREAD SNOWBOARDS"
  description="SPREAD SNOWBOARDSへのお問い合わせ。製品についてのご質問、ご注文等はこちらから。"
>
  <!-- Page Header -->
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-8 border-b border-white/5">
    <p class="text-red-500 text-[10px] tracking-[0.4em] uppercase mb-3">GET IN TOUCH</p>
    <h1 class="text-4xl sm:text-5xl font-black tracking-tight italic">CONTACT</h1>
  </div>

  <div class="max-w-3xl mx-auto px-6 py-16">
    <p class="text-white/40 text-sm leading-relaxed mb-12">
      製品についてのご質問、お取り扱いのご相談、その他お問い合わせは<br class="hidden sm:block" />
      以下のフォームよりお気軽にご連絡ください。
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      class="space-y-6"
      action="/contact/success"
    >
      <input type="hidden" name="form-name" value="contact" />

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-[10px] tracking-[0.3em] uppercase text-white/30 mb-2">
            お名前 <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="name"
            required
            class="w-full bg-transparent border border-white/15 text-white text-sm px-4 py-3 focus:outline-none focus:border-white/40 transition-colors placeholder-white/20"
            placeholder="山田 太郎"
          />
        </div>

        <div>
          <label class="block text-[10px] tracking-[0.3em] uppercase text-white/30 mb-2">
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            name="email"
            required
            class="w-full bg-transparent border border-white/15 text-white text-sm px-4 py-3 focus:outline-none focus:border-white/40 transition-colors placeholder-white/20"
            placeholder="your@email.com"
          />
        </div>
      </div>

      <div>
        <label class="block text-[10px] tracking-[0.3em] uppercase text-white/30 mb-2">
          件名
        </label>
        <select
          name="subject"
          class="w-full bg-black border border-white/15 text-white/70 text-sm px-4 py-3 focus:outline-none focus:border-white/40 transition-colors"
        >
          <option value="">選択してください</option>
          <option value="product">製品について</option>
          <option value="shop">取り扱い店舗について</option>
          <option value="dealer">販売代理店について</option>
          <option value="other">その他</option>
        </select>
      </div>

      <div>
        <label class="block text-[10px] tracking-[0.3em] uppercase text-white/30 mb-2">
          メッセージ <span class="text-red-500">*</span>
        </label>
        <textarea
          name="message"
          required
          rows="6"
          class="w-full bg-transparent border border-white/15 text-white text-sm px-4 py-3 focus:outline-none focus:border-white/40 transition-colors placeholder-white/20 resize-none"
          placeholder="お問い合わせ内容をご記入ください"
        ></textarea>
      </div>

      <button
        type="submit"
        class="inline-flex items-center gap-3 bg-white text-black text-xs font-bold tracking-[0.2em] uppercase px-8 py-3 hover:bg-red-600 hover:text-white transition-colors duration-200"
      >
        <span>SEND MESSAGE</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>
  </div>
</Layout>
