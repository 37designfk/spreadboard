---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const boards = await getCollection('boards');
  return boards.map(board => ({
    params: { slug: board.id },
  }));
}

const { slug } = Astro.params;
const board = await getEntry('boards', slug);

if (!board) {
  return Astro.redirect(`${import.meta.env.BASE_URL.replace(/\/$/, '')}/boards`);
}

const { data } = board;

const flexLabel = ['', 'SOFT', 'SOFT-MED', 'MEDIUM', 'MED-HARD', 'HARD'][data.flex];

// Related boards (same series)
const allBoards = await getCollection('boards');
const related = allBoards
  .filter(b => b.data.series === data.series && b.id !== board.id)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);
---

<Layout
  title={`${data.name} — SPREAD SNOWBOARDS`}
  description={`SPREAD SNOWBOARDS ${data.name}。${data.quality.join('/')}。${data.design}。`}
>
  <article class="max-w-7xl mx-auto px-6">
    <!-- Breadcrumb -->
    <div class="py-6 flex items-center gap-2 text-[10px] tracking-[0.2em] uppercase text-black/30">
      <a href={import.meta.env.BASE_URL.replace(/\/$/, '') || '/'} class="hover:text-black transition-colors">HOME</a>
      <span>/</span>
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/boards`} class="hover:text-black transition-colors">BOARDS</a>
      <span>/</span>
      <span class="text-black/60">{data.name}</span>
    </div>

    <!-- Main content -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 pb-16">
      <!-- Board Image -->
      <div class="flex gap-6 items-start justify-center">
        <!-- Top -->
        <div class="flex-1 max-w-[200px] bg-gradient-to-b from-gray-100 to-gray-50 border border-black/5 flex items-center justify-center py-8 min-h-[500px]">
          {data.topImage ? (
            <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${data.topImage}`} alt={`${data.name} top`} class="h-full max-h-[480px] w-auto object-contain" />
          ) : (
            <div class="text-black/10 text-center px-4">
              <svg width="60" height="60" viewBox="0 0 60 60" fill="none" class="mx-auto mb-2">
                <ellipse cx="30" cy="30" rx="10" ry="28" stroke="currentColor" stroke-width="1"/>
                <line x1="30" y1="2" x2="30" y2="58" stroke="currentColor" stroke-width="0.5"/>
              </svg>
              <p class="text-xs">TOP</p>
            </div>
          )}
        </div>
        <!-- Base -->
        <div class="flex-1 max-w-[200px] bg-gradient-to-b from-gray-50 to-white border border-black/5 flex items-center justify-center py-8 min-h-[500px]">
          {data.baseImage ? (
            <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${data.baseImage}`} alt={`${data.name} base`} class="h-full max-h-[480px] w-auto object-contain" />
          ) : (
            <div class="text-black/10 text-center px-4">
              <svg width="60" height="60" viewBox="0 0 60 60" fill="none" class="mx-auto mb-2">
                <ellipse cx="30" cy="30" rx="10" ry="28" stroke="currentColor" stroke-width="1"/>
              </svg>
              <p class="text-xs">BASE</p>
            </div>
          )}
        </div>
      </div>

      <!-- Info -->
      <div class="flex flex-col gap-8">
        <div>
          <p class="text-black/30 text-[10px] tracking-[0.4em] uppercase mb-2">
            {data.series} SERIES
          </p>
          <h1 class="text-5xl sm:text-6xl font-black tracking-tight italic text-black mb-4">
            {data.name}
          </h1>
          {data.designedBy && (
            <p class="text-black/40 text-xs tracking-widest uppercase">
              Designed by {data.designedBy}
            </p>
          )}
        </div>

        <!-- Quality -->
        <div>
          <p class="text-black/20 text-[10px] tracking-[0.3em] uppercase mb-3">Quality</p>
          <div class="flex flex-wrap gap-2">
            {data.quality.map(q => (
              <span class="border border-black/20 text-black/70 text-xs tracking-widest uppercase px-3 py-1.5">
                {q}
              </span>
            ))}
          </div>
        </div>

        <!-- Performance -->
        <div>
          <p class="text-black/20 text-[10px] tracking-[0.3em] uppercase mb-3">Performance</p>
          <p class="text-black/60 text-sm leading-[1.9]">{data.description}</p>
        </div>

        <!-- Flex & Design -->
        <div class="grid grid-cols-2 gap-6">
          <div>
            <p class="text-black/20 text-[10px] tracking-[0.3em] uppercase mb-3">Flex</p>
            <div class="flex gap-1 mb-1">
              {Array.from({ length: 5 }, (_, i) => (
                <div class:list={[
                  'h-1 flex-1',
                  i < data.flex ? 'bg-red-600' : 'bg-black/10'
                ]} />
              ))}
            </div>
            <p class="text-black/40 text-xs tracking-widest uppercase">{flexLabel}</p>
          </div>
          <div>
            <p class="text-black/20 text-[10px] tracking-[0.3em] uppercase mb-3">Design</p>
            <p class="text-black/70 text-sm font-medium tracking-widest uppercase">{data.design}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Size Chart -->
    <div class="border-t border-black/5 py-16">
      <h2 class="text-xs tracking-[0.4em] uppercase text-black/30 font-medium mb-8">Board Size</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-black/10">
              {[
                'SIZE', 'WAIST WIDTH', 'EFFECTIVE EDGE', 'RUNNING LENGTH',
                'SIDECUT RADIUS', 'STANCE WIDTH', 'NOSE/TAIL WIDTH', 'STANCE LOC.'
              ].map(h => (
                <th class="text-left py-3 pr-6 text-black/30 tracking-[0.15em] uppercase font-medium whitespace-nowrap">
                  {h}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {data.sizes.map(size => (
              <tr class="border-b border-black/5 hover:bg-gray-50 transition-colors">
                <td class="py-3 pr-6 text-black font-bold">
                  {size.size}{size.suffix || ''}
                </td>
                <td class="py-3 pr-6 text-black/60">{size.waistWidth}</td>
                <td class="py-3 pr-6 text-black/60">{size.effectiveEdge}</td>
                <td class="py-3 pr-6 text-black/60">{size.runningLength}</td>
                <td class="py-3 pr-6 text-black/60">{size.sidecutRadius}</td>
                <td class="py-3 pr-6 text-black/60">{size.stanceWidth}</td>
                <td class="py-3 pr-6 text-black/60">{size.noseTailWidth}</td>
                <td class="py-3 pr-6 text-black/60">{size.stanceLocation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Related Boards -->
    {related.length > 0 && (
      <div class="border-t border-black/5 py-16">
        <h2 class="text-xs tracking-[0.4em] uppercase text-black/30 font-medium mb-8">
          {data.series} SERIES — Other Models
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {related.map(b => (
            <a
              href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/boards/${b.id}`}
              class="border border-black/5 hover:border-black/20 p-5 transition-colors group bg-gray-50/50"
            >
              <p class="text-xs text-black/20 tracking-widest uppercase mb-2">{b.data.series}</p>
              <p class="text-lg font-bold tracking-widest italic text-black group-hover:text-red-600 transition-colors">
                {b.data.name}
              </p>
              <p class="text-black/30 text-xs mt-2">{b.data.design}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>
