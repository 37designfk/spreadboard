---
import Layout from '../../layouts/Layout.astro';
import BoardCard from '../../components/BoardCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allBoards = await getCollection('boards');
const sorted = allBoards.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const seriesOrder = ['LT', 'X', 'DX', 'ZERO', 'RD'];
const seriesLabels: Record<string, string> = {
  'LT': 'LT SERIES',
  'X': 'X SERIES',
  'DX': 'DX',
  'ZERO': 'ZERO',
  'RD': 'RD SERIES',
};

const grouped = seriesOrder.map(series => ({
  series,
  label: seriesLabels[series],
  boards: sorted.filter(b => b.data.series === series),
})).filter(g => g.boards.length > 0);
---

<Layout
  title="BOARDS 2026/27 — SPREAD SNOWBOARDS"
  description="SPREAD SNOWBOARDS 2026/27シーズンの全ボードラインナップ。LT、X、RDシリーズなど全11モデル。"
>
  <!-- Page Header -->
  <div class="max-w-7xl mx-auto px-6 pt-12 pb-8 border-b border-black/5">
    <p class="text-red-600 text-[10px] tracking-[0.4em] uppercase mb-3">2026 / 2027</p>
    <h1 class="text-4xl sm:text-5xl font-black tracking-tight italic">BOARDS</h1>
    <p class="text-black/30 text-sm mt-3">全 {allBoards.length} モデル</p>
  </div>

  <!-- Series Sections -->
  {grouped.map(({ series, label, boards }) => (
    <section class="max-w-7xl mx-auto px-6 py-16">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-xs tracking-[0.4em] uppercase text-black/40 font-medium">{label}</h2>
        <div class="flex-1 h-px bg-black/5"></div>
        <span class="text-black/20 text-xs">{boards.length} models</span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
        {boards.map(board => (
          <BoardCard
            name={board.data.name}
            series={board.data.series}
            quality={board.data.quality}
            design={board.data.design}
            flex={board.data.flex}
            slug={board.id}
            topImage={board.data.topImage}
          />
        ))}
      </div>
    </section>
  ))}

  <!-- PDF Download -->
  <div class="max-w-7xl mx-auto px-6 pb-16">
    <a
      href={`${base}/SPREAD_CATALOG2026JP.pdf`}
      target="_blank"
      class="flex items-center justify-between border border-black/10 p-6 hover:border-black/20 transition-colors group bg-gray-50/50"
    >
      <div>
        <p class="text-xs tracking-[0.2em] uppercase text-black/30 mb-1">CATALOG PDF</p>
        <p class="text-sm font-medium text-black group-hover:text-red-600 transition-colors">
          SPREAD SNOWBOARDS 2026/27 プロダクトマニュアル
        </p>
      </div>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="text-black/30 group-hover:text-black transition-colors flex-shrink-0">
        <path d="M9 2V12M5 8L9 12L13 8M2 15H16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</Layout>
