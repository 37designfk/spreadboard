---
interface Props {
  name: string;
  series: string;
  quality: string[];
  design: string;
  flex: number;
  slug: string;
  topImage?: string;
}

const { name, series, quality, design, flex, slug, topImage } = Astro.props;

const seriesColor: Record<string, string> = {
  'LT': 'bg-white/10 text-white/60',
  'X': 'bg-red-900/40 text-red-400',
  'RD': 'bg-white/5 text-white/40',
  'DX': 'bg-white/10 text-white/60',
  'ZERO': 'bg-white/5 text-white/40',
};

const flexLabels = ['', 'SOFT', 'SOFT-MED', 'MEDIUM', 'MED-HARD', 'HARD'];
---

<a
  href={`/boards/${slug}`}
  class="group block bg-[#0a0a0a] border border-white/5 hover:border-white/20 transition-all duration-300 overflow-hidden"
>
  <!-- Board image placeholder -->
  <div class="relative aspect-[1/2.5] bg-gradient-to-b from-zinc-900 to-zinc-950 overflow-hidden flex items-center justify-center">
    {topImage ? (
      <img
        src={topImage}
        alt={name}
        class="h-full w-auto object-contain group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="flex flex-col items-center gap-2 text-white/10">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
          <ellipse cx="20" cy="20" rx="6" ry="18" stroke="currentColor" stroke-width="1"/>
          <line x1="20" y1="2" x2="20" y2="38" stroke="currentColor" stroke-width="0.5"/>
        </svg>
        <span class="text-xs tracking-widest uppercase">{name}</span>
      </div>
    )}
    <!-- Series badge -->
    <div class="absolute top-3 left-3">
      <span class:list={['text-[10px] tracking-[0.2em] uppercase px-2 py-1 font-medium', seriesColor[series] || 'bg-white/10 text-white/50']}>
        {series} SERIES
      </span>
    </div>
  </div>

  <!-- Info -->
  <div class="p-5">
    <h3 class="text-lg font-bold tracking-[0.15em] uppercase text-white group-hover:text-red-400 transition-colors mb-3">
      {name}
    </h3>

    <div class="flex flex-wrap gap-1 mb-4">
      {quality.map(q => (
        <span class="text-[10px] tracking-widest uppercase text-white/40 border border-white/10 px-2 py-0.5">
          {q}
        </span>
      ))}
    </div>

    <div class="flex items-center justify-between text-xs text-white/30 uppercase tracking-widest">
      <span>{design}</span>
      <span>{flexLabels[flex]}</span>
    </div>

    <!-- Flex bar -->
    <div class="mt-3 flex gap-0.5">
      {Array.from({ length: 5 }, (_, i) => (
        <div class:list={[
          'h-0.5 flex-1 transition-colors',
          i < flex ? 'bg-red-600' : 'bg-white/10'
        ]} />
      ))}
    </div>
  </div>
</a>
